# ============================================================================
#  AIRDROP DISTRIBUTOR — copy to `.env`. `.env` is gitignored.
#  ⚠️ Jalankan app ini SECARA LOKAL / private. JANGAN expose ke publik:
#     file ini memegang PRIVATE KEY treasury.
# ============================================================================

# --- RPC (pakai Helius key yang sudah kamu punya) ---------------------------
# Format Helius RPC: https://mainnet.helius-rpc.com/?api-key=XXXX
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=PASTE_HELIUS_KEY

# --- Moralis (read-only: ambil top holders) ---------------------------------
# Gratis di https://moralis.com (Dashboard -> API Keys).
MORALIS_API_KEY=

# --- Token holder kamu (yang holdernya menerima airdrop) --------------------
# CA token project kamu. Top 100 holder token INI yang dapat coin pemenang.
PROJECT_TOKEN_MINT=

# --- Mint kandidat pemenang (dari game ANSEM vs TJR) ------------------------
ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump
TJR_MINT=4U4U8oXwDyVXGeTffMXds4NAgBgLFwq3wNvTCRTSpump

# --- Treasury wallet (SUMBER coin pemenang + bayar fee/rent) ----------------
# Private key base58 (export dari Phantom) ATAU JSON array (Solana CLU id.json).
# ⚠️ RAHASIA. Jangan commit, jangan kirim ke siapa pun.
TREASURY_PRIVATE_KEY=

# --- Password endpoint /api/execute (cegah trigger sembarangan) -------------
ADMIN_SECRET=ganti-dengan-passphrase-panjang

# --- Tuning -----------------------------------------------------------------
HOLDER_COUNT=100          # jumlah holder asli target (setelah filter)
PER_TX_TRANSFERS=5        # transfer per transaksi (turunkan bila kena size limit)
# Alamat yang di-exclude manual (LP/CEX/team), pisah koma:
EXCLUDE_ADDRESSES=

PORT=4000
